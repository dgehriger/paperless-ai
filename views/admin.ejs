<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Paperless-AI</title>
    <script src="https://cdn.tailwindcss.com/3.4.16"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .tab-btn { padding: 0.5rem 1rem; border-bottom: 2px solid transparent; cursor: pointer; font-weight: 500; color: #6b7280; }
        .tab-btn.active { border-bottom-color: #6366f1; color: #6366f1; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
        .badge-green { background: #d1fae5; color: #065f46; }
        .badge-yellow { background: #fef3c7; color: #92400e; }
        .badge-blue { background: #dbeafe; color: #1e40af; }
        .badge-red { background: #fee2e2; color: #991b1b; }
        .perm-chip { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.125rem 0.5rem; border-radius: 0.375rem; font-size: 0.75rem; background: #f3f4f6; border: 1px solid #e5e7eb; cursor: pointer; user-select: none; }
        .perm-chip.selected { background: #dbeafe; border-color: #93c5fd; color: #1e40af; }
        .lib-filter-row { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 0.75rem; border-bottom: 1px solid #e5e7eb; }
        th { font-weight: 600; font-size: 0.875rem; color: #6b7280; }
        .action-btn { padding: 0.25rem 0.5rem; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer; border: 1px solid #e5e7eb; background: white; }
        .action-btn:hover { background: #f9fafb; }
        .action-btn.danger { color: #dc2626; border-color: #fecaca; }
        .action-btn.danger:hover { background: #fee2e2; }
        .action-btn.primary { color: #2563eb; border-color: #bfdbfe; }
        .action-btn.primary:hover { background: #dbeafe; }
        .action-btn.success { color: #16a34a; border-color: #bbf7d0; }
        .action-btn.success:hover { background: #dcfce7; }
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 50; display: flex; align-items: center; justify-content: center; }
        .modal { background: white; border-radius: 0.75rem; padding: 1.5rem; width: 100%; max-width: 32rem; max-height: 80vh; overflow-y: auto; box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); }
        .modal h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 1rem; }
        .form-group { margin-bottom: 1rem; }
        .form-group label { display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.25rem; }
        .form-group input, .form-group textarea { width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.875rem; }
        .form-group textarea { resize: vertical; min-height: 3rem; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="max-w-6xl mx-auto px-4 py-6">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
                <a href="/dashboard" class="text-gray-500 hover:text-gray-700"><i class="fas fa-arrow-left"></i></a>
                <h1 class="text-2xl font-bold">Admin Panel</h1>
            </div>
        </div>

        <!-- Tabs -->
        <div class="flex gap-4 border-b mb-6">
            <button class="tab-btn active" data-tab="users"><i class="fas fa-users mr-1"></i> Users</button>
            <button class="tab-btn" data-tab="libraries"><i class="fas fa-book mr-1"></i> Libraries</button>
        </div>

        <!-- Users Tab -->
        <div id="tab-users" class="tab-content active">
            <div id="users-table-container">
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Status</th>
                            <th>Role</th>
                            <th>Permissions</th>
                            <th>Libraries</th>
                            <th>Last Login</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="users-tbody"></tbody>
                </table>
            </div>
        </div>

        <!-- Libraries Tab -->
        <div id="tab-libraries" class="tab-content">
            <div class="mb-4">
                <button id="add-library-btn" class="action-btn primary"><i class="fas fa-plus mr-1"></i> New Library</button>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Filters</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="libraries-tbody"></tbody>
            </table>
        </div>
    </div>

    <!-- Modal container -->
    <div id="modal-container"></div>

    <script>
    // State
    let allUsers = [];
    let allLibraries = [];
    let allPermissions = [];

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
        });
    });

    // Load data
    async function loadData() {
        const res = await fetch('/api/admin/users');
        const data = await res.json();
        allUsers = data.users;
        allPermissions = data.allPermissions;
        allLibraries = data.libraries;
        renderUsers();
        renderLibraries();
    }

    function renderUsers() {
        const tbody = document.getElementById('users-tbody');
        tbody.innerHTML = allUsers.map(u => {
            const status = u.is_approved
                ? '<span class="badge badge-green">Approved</span>'
                : '<span class="badge badge-yellow">Pending</span>';
            const role = u.is_admin
                ? '<span class="badge badge-blue">Admin</span>'
                : '<span class="badge">User</span>';
            const perms = (u.permissions || []).map(p => `<span class="perm-chip selected">${p}</span>`).join(' ');
            const userLibs = '<span class="text-sm text-gray-500">' +
                (allLibraries.filter(l => u._libraryIds && u._libraryIds.includes(l.id)).map(l => l.name).join(', ') || '—') +
                '</span>';
            const lastLogin = u.last_login ? new Date(u.last_login).toLocaleDateString() : 'Never';

            return `<tr>
                <td>
                    <div class="font-medium">${escHtml(u.name)}</div>
                    <div class="text-sm text-gray-500">${escHtml(u.email)}</div>
                </td>
                <td>${status}</td>
                <td>${role}</td>
                <td>${perms || '<span class="text-gray-400">None</span>'}</td>
                <td>${userLibs}</td>
                <td class="text-sm text-gray-500">${lastLogin}</td>
                <td class="flex gap-1 flex-wrap">
                    ${!u.is_approved ? `<button class="action-btn success" onclick="approveUser('${u.id}', true)"><i class="fas fa-check"></i> Approve</button>` : `<button class="action-btn" onclick="approveUser('${u.id}', false)"><i class="fas fa-ban"></i> Revoke</button>`}
                    <button class="action-btn primary" onclick="editUser('${u.id}')"><i class="fas fa-edit"></i></button>
                    <button class="action-btn danger" onclick="deleteUser('${u.id}')"><i class="fas fa-trash"></i></button>
                </td>
            </tr>`;
        }).join('');
    }

    function renderLibraries() {
        const tbody = document.getElementById('libraries-tbody');
        tbody.innerHTML = allLibraries.map(l => {
            const f = l.filters || {};
            const filterParts = [];
            if (f.storage_paths?.length) filterParts.push('Paths: ' + f.storage_paths.join(', '));
            if (f.tags?.length) filterParts.push('Tags: ' + f.tags.join(', '));
            if (f.correspondents?.length) filterParts.push('Correspondents: ' + f.correspondents.join(', '));
            if (f.document_types?.length) filterParts.push('Types: ' + f.document_types.join(', '));
            const filtersStr = filterParts.join(' | ') || '<span class="text-gray-400">No filters (all documents)</span>';

            return `<tr>
                <td class="font-medium">${escHtml(l.name)}</td>
                <td class="text-sm text-gray-500">${escHtml(l.description || '')}</td>
                <td class="text-sm">${filtersStr}</td>
                <td class="flex gap-1">
                    <button class="action-btn primary" onclick="editLibrary('${l.id}')"><i class="fas fa-edit"></i></button>
                    <button class="action-btn danger" onclick="deleteLibrary('${l.id}')"><i class="fas fa-trash"></i></button>
                </td>
            </tr>`;
        }).join('');
    }

    // Actions
    async function approveUser(id, approved) {
        await fetch(`/api/admin/users/${id}/approve`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ approved })
        });
        await loadData();
    }

    async function deleteUser(id) {
        if (!confirm('Delete this user? This cannot be undone.')) return;
        await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
        await loadData();
    }

    function editUser(id) {
        const user = allUsers.find(u => u.id === id);
        if (!user) return;

        showModal(`
            <h3>Edit User: ${escHtml(user.email)}</h3>
            <div class="form-group">
                <label>Permissions</label>
                <div class="flex flex-wrap gap-1" id="perm-chips">
                    ${allPermissions.map(p => {
                        const sel = user.permissions.includes(p) ? 'selected' : '';
                        return `<span class="perm-chip ${sel}" data-perm="${p}" onclick="this.classList.toggle('selected')">${p}</span>`;
                    }).join('')}
                </div>
            </div>
            <div class="form-group">
                <label>Libraries</label>
                <div class="flex flex-wrap gap-1" id="lib-chips">
                    ${allLibraries.map(l => {
                        return `<span class="perm-chip" data-lib="${l.id}" onclick="this.classList.toggle('selected')">${escHtml(l.name)}</span>`;
                    }).join('')}
                </div>
            </div>
            <div class="form-group">
                <label><input type="checkbox" id="is-admin-cb" ${user.is_admin ? 'checked' : ''}> Admin</label>
            </div>
            <div class="flex gap-2 justify-end mt-4">
                <button class="action-btn" onclick="closeModal()">Cancel</button>
                <button class="action-btn primary" onclick="saveUser('${id}')">Save</button>
            </div>
        `);
    }

    async function saveUser(id) {
        const perms = Array.from(document.querySelectorAll('#perm-chips .perm-chip.selected')).map(el => el.dataset.perm);
        const libs = Array.from(document.querySelectorAll('#lib-chips .perm-chip.selected')).map(el => el.dataset.lib);
        const isAdmin = document.getElementById('is-admin-cb').checked;

        await Promise.all([
            fetch(`/api/admin/users/${id}/permissions`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ permissions: perms })
            }),
            fetch(`/api/admin/users/${id}/libraries`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ libraryIds: libs })
            }),
            fetch(`/api/admin/users/${id}/admin`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ isAdmin })
            }),
        ]);
        closeModal();
        await loadData();
    }

    // Library CRUD
    document.getElementById('add-library-btn').addEventListener('click', () => editLibrary(null));

    function editLibrary(id) {
        const lib = id ? allLibraries.find(l => l.id === id) : { name: '', description: '', filters: {} };
        if (!lib) return;
        const f = lib.filters || {};

        showModal(`
            <h3>${id ? 'Edit' : 'New'} Library</h3>
            <div class="form-group">
                <label>Name</label>
                <input id="lib-name" value="${escHtml(lib.name)}">
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea id="lib-desc">${escHtml(lib.description || '')}</textarea>
            </div>
            <div class="form-group">
                <label>Storage Paths (comma-separated)</label>
                <input id="lib-paths" value="${escHtml((f.storage_paths || []).join(', '))}">
            </div>
            <div class="form-group">
                <label>Tags (comma-separated)</label>
                <input id="lib-tags" value="${escHtml((f.tags || []).join(', '))}">
            </div>
            <div class="form-group">
                <label>Correspondents (comma-separated)</label>
                <input id="lib-correspondents" value="${escHtml((f.correspondents || []).join(', '))}">
            </div>
            <div class="form-group">
                <label>Document Types (comma-separated)</label>
                <input id="lib-types" value="${escHtml((f.document_types || []).join(', '))}">
            </div>
            <div class="flex gap-2 justify-end mt-4">
                <button class="action-btn" onclick="closeModal()">Cancel</button>
                <button class="action-btn primary" onclick="saveLibrary(${id ? `'${id}'` : 'null'})">Save</button>
            </div>
        `);
    }

    async function saveLibrary(id) {
        const split = v => v.split(',').map(s => s.trim()).filter(s => s);
        const body = {
            name: document.getElementById('lib-name').value,
            description: document.getElementById('lib-desc').value,
            filters: {
                storage_paths: split(document.getElementById('lib-paths').value),
                tags: split(document.getElementById('lib-tags').value),
                correspondents: split(document.getElementById('lib-correspondents').value),
                document_types: split(document.getElementById('lib-types').value),
            }
        };
        const url = id ? `/api/admin/libraries/${id}` : '/api/admin/libraries';
        const method = id ? 'PUT' : 'POST';
        await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        closeModal();
        await loadData();
    }

    async function deleteLibrary(id) {
        if (!confirm('Delete this library?')) return;
        await fetch(`/api/admin/libraries/${id}`, { method: 'DELETE' });
        await loadData();
    }

    // Modal helpers
    function showModal(html) {
        document.getElementById('modal-container').innerHTML =
            `<div class="modal-overlay" onclick="if(event.target===this)closeModal()"><div class="modal">${html}</div></div>`;
    }
    function closeModal() {
        document.getElementById('modal-container').innerHTML = '';
    }

    function escHtml(str) {
        const div = document.createElement('div');
        div.textContent = str || '';
        return div.innerHTML;
    }

    // Init
    loadData();
    </script>
</body>
</html>
